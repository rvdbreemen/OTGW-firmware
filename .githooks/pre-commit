#!/usr/bin/env bash
# adr-kit pre-commit hook (template; copied to project's .githooks/pre-commit by /adr-kit:install-hooks).
#
# Resolves the latest installed adr-kit version dynamically so plugin upgrades
# don't require re-running install-hooks. Degrades gracefully when the plugin
# cache is missing — the hook never blocks a commit because of tooling drift.
#
# As of v0.13.0 the LLM pass (Claude Sonnet) is enabled by default. ADRs with
# `"llm_judge": true` are evaluated against the staged diff via `claude -p`.
# A missing `claude` CLI logs a warning and falls back to declarative-only.
#
# Disable LLM pass per commit:  ADR_KIT_NO_LLM=1 git commit ...
# Disable hook entirely:        ADR_KIT_HOOK_DISABLE=1 git commit ...
# Remove permanently:           /adr-kit:install-hooks --uninstall  (in a Claude Code session)

set -e

if [ "${ADR_KIT_HOOK_DISABLE:-0}" = "1" ]; then
  echo "[adr-kit] hook disabled for this commit (ADR_KIT_HOOK_DISABLE=1)" >&2
  exit 0
fi

ADR_KIT_BASE="${HOME}/.claude/plugins/cache/rvdbreemen-adr-kit/adr-kit"
ADR_JUDGE=""
if [ -d "$ADR_KIT_BASE" ]; then
  # Pick the highest installed version (lexicographic sort works for SemVer-shaped dirs).
  ADR_JUDGE=$(ls -d "$ADR_KIT_BASE"/*/bin/adr-judge 2>/dev/null | sort -V | tail -1)
fi

if [ -z "$ADR_JUDGE" ] || [ ! -x "$ADR_JUDGE" ]; then
  echo "[adr-kit] adr-judge binary not found in plugin cache; skipping pre-commit ADR check." >&2
  echo "[adr-kit] Re-install with /adr-kit:install-hooks in a Claude Code session." >&2
  exit 0
fi

ROOT=$(git rev-parse --show-toplevel)
DIFF=$(git diff --cached --unified=0)
if [ -z "$DIFF" ]; then
  exit 0
fi

# Run the judge. Default mode (v0.13.0+):
#   - declarative pass:  fast, regex-only, exits non-zero on violation
#   - LLM pass:          claude -p --model claude-sonnet-4-6 evaluates llm_judge:true
#                        ADRs in one batched call; falls back gracefully if `claude`
#                        is missing or unauthenticated
# Exit codes:
#   0  no violations (advisory entries are non-blocking)
#   1  at least one violation (declarative or LLM)
#   2  config or runtime error
ADR_OUT=$(echo "$DIFF" | "$ADR_JUDGE" --diff - --adr-dir "$ROOT/docs/adr/" --llm 2>&1)
ADR_EXIT=$?
# Suppress per-ADR llm_judge advisory lines: they repeat once per ADR with llm_judge:true
# and become very noisy on projects with many ADRs. Violations and the summary line
# (e.g. "[adr-judge] OK 0 violations, 57 advisory") are preserved.
printf '%s\n' "$ADR_OUT" | grep -avE "^  ADVISORY |^[[:space:]]+ADR has llm_judge:true" >&2 || true
[ "$ADR_EXIT" -ne 0 ] && exit "$ADR_EXIT"

exit 0
