#!/usr/bin/env bash
# Pre-commit hook for OTGW-firmware 2.0.0 worktree.
# Two independent checks run on every commit:
#   1. Firmware version-bump check (OTGW-specific)
#   2. ADR-compliance check via adr-kit
#
# Per-check bypass:
#   OTGW_BUMP_HOOK_DISABLE=1 git commit ...   — skip bump check only
#   ADR_KIT_HOOK_DISABLE=1 git commit ...     — skip ADR check only
#   ADR_KIT_NO_LLM=1 git commit ...           — skip LLM pass, declarative only

set -e

# ── 1. OTGW firmware version-bump check ──────────────────────────────────────

if [ "${OTGW_BUMP_HOOK_DISABLE:-0}" != "1" ]; then
  STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
  TRIGGER=$(echo "$STAGED" | awk '
    /^src\/OTGW-firmware\/version\.h$/ { next }
    /^src\/OTGW-firmware\// { print; next }
    /^src\/libraries\// { print; next }
  ')

  if [ -n "$TRIGGER" ]; then
    PRERELEASE_DIFF=$(git diff --cached -- src/OTGW-firmware/version.h | grep -E '^[+-]#define _VERSION_PRERELEASE ' || true)
    MINUS=$(echo "$PRERELEASE_DIFF" | grep -c '^-' || true)
    PLUS=$(echo "$PRERELEASE_DIFF" | grep -c '^+' || true)

    if [ "$MINUS" -lt 1 ] || [ "$PLUS" -lt 1 ]; then
      echo "" >&2
      echo "[bump] commit touches firmware code but does not bump _VERSION_PRERELEASE." >&2
      echo "[bump] Run bin/bump-prerelease.sh and stage src/OTGW-firmware/version.h + data/version.hash" >&2
      echo "[bump] alongside your code change." >&2
      echo "[bump] Bypass for this commit: OTGW_BUMP_HOOK_DISABLE=1 git commit ..." >&2
      echo "" >&2
      echo "[bump] Triggering paths in this commit:" >&2
      echo "$TRIGGER" | sed 's/^/  /' >&2
      exit 1
    fi
  fi
fi

# ── 2. adr-kit ADR-compliance check ──────────────────────────────────────────
# Mirrors the canonical adr-kit hook template (templates/githooks/pre-commit) so
# this project's copy stays in sync with upstream: Python 3 detection validated
# by --version (handles PATH shims that report a real version), SemVer-highest
# plugin-cache pick via nullglob, and dynamic resolution so plugin upgrades don't
# require re-running install-hooks. Never blocks a commit due to tooling drift.

if [ "${ADR_KIT_HOOK_DISABLE:-0}" != "1" ]; then
  # Find a Python 3 interpreter (adr-judge is a Python 3 script). Validate via
  # --version rather than presence alone so a non-functional PATH entry is skipped.
  _PYTHON3=""
  for _cmd in python3 python py; do
    if command -v "$_cmd" >/dev/null 2>&1; then
      _ver=$("$_cmd" --version 2>&1 | grep -oE '[0-9]+\.[0-9]+' | head -1)
      _major=$(echo "$_ver" | cut -d. -f1)
      if [ "${_major:-0}" -ge 3 ] 2>/dev/null; then
        _PYTHON3="$_cmd"; break
      fi
    fi
  done

  if [ -z "$_PYTHON3" ]; then
    echo "[adr-kit] Python 3 not found; skipping ADR check." >&2
  else
    ADR_KIT_BASE="${HOME}/.claude/plugins/cache/rvdbreemen-adr-kit/adr-kit"
    ADR_JUDGE=""
    if [ -d "$ADR_KIT_BASE" ]; then
      shopt -s nullglob
      _candidates=("$ADR_KIT_BASE"/*/bin/adr-judge)
      shopt -u nullglob
      if [ ${#_candidates[@]} -gt 0 ]; then
        ADR_JUDGE=$(printf '%s\n' "${_candidates[@]}" | sort -V | tail -1)
      fi
    fi

    if [ -z "$ADR_JUDGE" ] || [ ! -f "$ADR_JUDGE" ]; then
      echo "[adr-kit] adr-judge not found in plugin cache; skipping ADR check." >&2
      echo "[adr-kit] Re-install with /adr-kit:install-hooks in a Claude Code session." >&2
    else
      ROOT=$(git rev-parse --show-toplevel)
      DIFF=$(git diff --cached --unified=0)
      if [ -n "$DIFF" ]; then
        ADR_OUT=$(echo "$DIFF" | "$_PYTHON3" "$ADR_JUDGE" --diff - --adr-dir "$ROOT/docs/adr/" --llm 2>&1)
        ADR_EXIT=$?
        printf '%s\n' "$ADR_OUT" | grep -avE "^  ADVISORY |^[[:space:]]+ADR has llm_judge:true" >&2 || true
        [ "$ADR_EXIT" -ne 0 ] && exit "$ADR_EXIT"
      fi
    fi
  fi
fi

# ── 3. adr-kit ADR-suggestion advisory ───────────────────────────────────────
# Non-blocking decision detector: runs `adr-suggest` over the staged diff and
# prints a hint when the change looks like a NEW architectural decision that may
# warrant an ADR (distinct from section 2, which only enforces EXISTING ADRs).
# NEVER affects the commit outcome. Requires adr-kit >= 0.16.0 in the plugin
# cache; silently skips if the bin is absent (e.g. before a plugin upgrade).
# Disable per-commit with: ADR_KIT_SUGGEST_DISABLE=1 git commit ...
if [ "${ADR_KIT_SUGGEST_DISABLE:-0}" != "1" ]; then
  _PYTHON3S=""
  for _cmd in python3 python py; do
    if command -v "$_cmd" >/dev/null 2>&1; then
      _ver=$("$_cmd" --version 2>&1 | grep -oE '[0-9]+\.[0-9]+' | head -1)
      _major=$(echo "$_ver" | cut -d. -f1)
      if [ "${_major:-0}" -ge 3 ] 2>/dev/null; then _PYTHON3S="$_cmd"; break; fi
    fi
  done

  if [ -n "$_PYTHON3S" ]; then
    ADR_KIT_BASE_S="${HOME}/.claude/plugins/cache/rvdbreemen-adr-kit/adr-kit"
    ADR_SUGGEST=""
    if [ -d "$ADR_KIT_BASE_S" ]; then
      shopt -s nullglob
      _candidates_s=("$ADR_KIT_BASE_S"/*/bin/adr-suggest)
      shopt -u nullglob
      if [ ${#_candidates_s[@]} -gt 0 ]; then
        ADR_SUGGEST=$(printf '%s\n' "${_candidates_s[@]}" | sort -V | tail -1)
      fi
    fi

    if [ -n "$ADR_SUGGEST" ] && [ -f "$ADR_SUGGEST" ]; then
      ROOT_S=$(git rev-parse --show-toplevel)
      DIFF_S=$(git diff --cached --unified=0)
      if [ -n "$DIFF_S" ]; then
        # Advisory text goes to stderr; exit status is always swallowed so a
        # detector hiccup can never block a commit.
        echo "$DIFF_S" | "$_PYTHON3S" "$ADR_SUGGEST" --diff - --adr-dir "$ROOT_S/docs/adr/" >&2 || true
      fi
    fi
  fi
fi

exit 0
