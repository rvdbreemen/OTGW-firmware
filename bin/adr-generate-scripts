#!/usr/bin/env python3
"""adr-generate-scripts: generate standalone validation scripts from ADR Enforcement blocks.

Creates executable scripts (Python, Shell) that validate code against ADR Enforcement
rules without requiring adr-kit. Generated scripts read from stdin and exit 0 on clean,
1 on violation.

Usage:
  adr-generate-scripts
  adr-generate-scripts --output .generated/
  adr-generate-scripts --lang shell
  adr-generate-scripts --lang python
  adr-generate-scripts --lang all
  adr-generate-scripts --adr-dir docs/decisions
"""

from __future__ import annotations

import argparse
import json
import re
import sys
from pathlib import Path
from typing import Dict, List, Optional

# Mirrors adr-judge's ENFORCEMENT_BLOCK_RE exactly so extraction is consistent.
ENFORCEMENT_BLOCK_RE = re.compile(
    r"^##\s+Enforcement\s*$\n+(?:.*?\n)*?```json\s*\n(.*?)\n```",
    re.IGNORECASE | re.MULTILINE | re.DOTALL,
)

ADR_FILENAME_RE = re.compile(r"(?i)^ADR-(\d{1,4})-.*\.md$")


def adr_id_from_filename(name: str) -> Optional[str]:
    """Return normalised ADR-NNN id from a filename, or None."""
    m = ADR_FILENAME_RE.match(name)
    if not m:
        return None
    return f"ADR-{int(m.group(1)):03d}"


def extract_enforcement(content: str) -> Optional[Dict]:
    """Extract and parse the Enforcement JSON block from an ADR.

    Returns None when no Enforcement section is present.
    Raises ValueError when the section exists but contains malformed JSON.
    """
    m = ENFORCEMENT_BLOCK_RE.search(content)
    if not m:
        return None
    raw = m.group(1)
    try:
        data = json.loads(raw)
    except json.JSONDecodeError as e:
        raise ValueError(f"malformed JSON in ## Enforcement block: {e}")
    if not isinstance(data, dict):
        raise ValueError(f"Enforcement JSON must be an object, got {type(data).__name__}")
    return data


def _collect_forbid_rules(enforcement: Dict) -> List[Dict]:
    """Collect all forbid_pattern and forbid_import rules into one flat list.

    Both rule types use identical structure {pattern, message, path_glob?}
    and are evaluated the same way (regex match) in adr-judge.
    """
    rules = []
    for kind in ("forbid_pattern", "forbid_import"):
        for rule in enforcement.get(kind, []):
            pattern = rule.get("pattern", "")
            message = rule.get("message") or f"{kind}: {pattern}"
            if pattern:
                rules.append({"pattern": pattern, "message": message})
    return rules


def generate_python_script(adr_id: str, rules: List[Dict]) -> str:
    """Generate a standalone Python validation script with ADR rules injected."""
    rule_entries = []
    for rule in rules:
        pattern_repr = repr(rule["pattern"])
        message_repr = repr(rule["message"])
        rule_entries.append(f"    (re.compile({pattern_repr}), {message_repr}),")

    rules_block = "\n".join(rule_entries) if rule_entries else "    # no forbid rules"

    return f"""\
#!/usr/bin/env python3
# Generated by adr-kit for {adr_id}. Do not edit manually.
# Validates stdin against {adr_id} enforcement rules.
# Usage: cat file.py | python validate.py
# Exit 0 = clean, exit 1 = violations found.

import re
import sys

FORBID_RULES = [
{rules_block}
]


def main():
    lines = sys.stdin.readlines()
    violations = 0
    for i, line in enumerate(lines, 1):
        for pattern, message in FORBID_RULES:
            if pattern.search(line):
                print(f"VIOLATION line {{i}}: {{message}}", file=sys.stderr)
                print(f"  {{line.rstrip()}}", file=sys.stderr)
                violations += 1
    sys.exit(1 if violations > 0 else 0)


if __name__ == "__main__":
    main()
"""


def _shell_escape_pattern(pattern: str) -> str:
    """Escape a regex pattern for single-quoted use in a shell grep -E call."""
    return pattern.replace("'", "'\\''")


def _shell_escape_message(msg: str) -> str:
    """Escape a message for single-quoted shell string."""
    return msg.replace("'", "'\\''")


def generate_shell_script(adr_id: str, rules: List[Dict]) -> str:
    """Generate a standalone POSIX shell validation script with ADR rules injected.

    Performance: uses ONE grep pass per rule against the full input
    (O(rules) subprocess spawns), not one per (line × rule) which would be
    O(lines × rules) — that pegs CPU on large files for no benefit.
    """
    check_calls = []
    pattern_list = []
    for rule in rules:
        pattern = _shell_escape_pattern(rule["pattern"])
        message = _shell_escape_message(rule["message"])
        check_calls.append(f"check_rule '{pattern}' '{message}'")
        pattern_list.append(f"  '{pattern}'")

    checks_block = "\n".join(check_calls) if check_calls else "# no forbid rules configured"
    patterns_block = "\n".join(pattern_list) if pattern_list else "  # no patterns"

    return f"""\
#!/bin/bash
# Generated by adr-kit for {adr_id}. Do not edit manually.
# Validates stdin against {adr_id} enforcement rules.
# Usage: cat file.py | bash validate.sh
# Exit 0 = clean, exit 1 = violations found.
#
# Note: regex flavour is POSIX ERE (grep -E). For authoritative validation
# (Python regex flavour, llm_judge, etc.) use adr-judge.

set -euo pipefail

# --- Pattern validation at startup --------------------------------------
# Test each pattern against an empty input. If grep -E rejects it, the
# pattern is not valid POSIX ERE and results below may be incomplete.
_INVALID=0
for _pat in \\
{patterns_block}
do
  if ! printf '' | grep -qE -- "$_pat" 2>/dev/null; then
    printf '[adr-validate] WARN: invalid ERE pattern: %s\\n' "$_pat" >&2
    _INVALID=1
  fi
done
if [ "$_INVALID" -eq 1 ]; then
  printf '%s\\n' '[adr-validate] WARN: some patterns invalid for ERE (grep). Results may be incomplete. Use adr-judge for authoritative validation.' >&2
fi

# --- Main validation ---------------------------------------------------
VIOLATIONS=0
INPUT=$(cat)

# check_rule runs ONE grep -nE pass over the full input for a single
# pattern. grep prints "lineno:matchedline" for each hit; we reformat to
# the standard VIOLATION shape. This is O(1) subprocess spawn per rule.
check_rule() {{
    local pattern="$1"
    local message="$2"
    local matches
    # grep -n: line numbers; -E: ERE; || true: don't trigger set -e on no-match
    matches=$(printf '%s\\n' "$INPUT" | grep -nE -- "$pattern" || true)
    if [ -n "$matches" ]; then
        while IFS= read -r hit; do
            [ -z "$hit" ] && continue
            local lineno="${{hit%%:*}}"
            local content="${{hit#*:}}"
            printf 'VIOLATION line %s: %s\\n' "$lineno" "$message" >&2
            printf '  %s\\n' "$content" >&2
            VIOLATIONS=$((VIOLATIONS + 1))
        done <<< "$matches"
    fi
}}

{checks_block}

[ "$VIOLATIONS" -gt 0 ] && exit 1
exit 0
"""


def _make_executable(path: Path) -> None:
    """Add user-execute bit to path. No-op on Windows.

    Deliberately user-only (S_IXUSR) — generated scripts may live in shared
    work-trees; world/group +x is unnecessary and a mild SEC concern.
    """
    try:
        import stat
        current = path.stat().st_mode
        path.chmod(current | stat.S_IXUSR)
    except (AttributeError, NotImplementedError):
        pass  # Windows — chmod is a no-op


def generate_scripts_for_adr(
    adr_id: str,
    enforcement: Dict,
    output_dir: Path,
    langs: List[str],
) -> List[Path]:
    """Generate scripts for one ADR. Returns list of written file paths."""
    rules = _collect_forbid_rules(enforcement)
    if not rules:
        return []

    adr_output = output_dir / adr_id
    adr_output.mkdir(parents=True, exist_ok=True)

    written = []
    if "python" in langs:
        p = adr_output / "validate.py"
        p.write_text(generate_python_script(adr_id, rules), encoding="utf-8")
        _make_executable(p)
        written.append(p)

    if "shell" in langs:
        p = adr_output / "validate.sh"
        p.write_text(generate_shell_script(adr_id, rules), encoding="utf-8", newline="\n")
        _make_executable(p)
        written.append(p)

    return written


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Generate standalone ADR enforcement validation scripts."
    )
    parser.add_argument(
        "--output",
        type=Path,
        default=Path(".generated"),
        help="Output directory (default: .generated)",
    )
    parser.add_argument(
        "--lang",
        choices=["python", "shell", "all"],
        default="all",
        help="Language(s) to generate (default: all)",
    )
    parser.add_argument(
        "--adr-dir",
        type=Path,
        default=None,
        help="Directory containing ADR-*.md files (default: docs/adr)",
    )
    parser.add_argument(
        "adr_dir_positional",
        nargs="?",
        default=None,
        metavar="adr_dir",
        help="Directory containing ADR-*.md files (positional alternative to --adr-dir)",
    )

    args = parser.parse_args()

    # Resolve ADR dir: --adr-dir wins over positional, then default.
    if args.adr_dir is not None:
        adr_dir = args.adr_dir
    elif args.adr_dir_positional is not None:
        adr_dir = Path(args.adr_dir_positional)
    else:
        adr_dir = Path("docs/adr")

    if args.lang == "all":
        langs = ["python", "shell"]
    else:
        langs = [args.lang]

    output_dir = args.output
    output_dir.mkdir(parents=True, exist_ok=True)

    if not adr_dir.is_dir():
        print(f"[adr-generate-scripts] ERROR: ADR directory not found: {adr_dir}", file=sys.stderr)
        return 2

    adr_files = sorted(adr_dir.glob("ADR-*.md"))
    if not adr_files:
        print(f"[adr-generate-scripts] No ADR-*.md files found in {adr_dir}", file=sys.stderr)
        return 0

    total_written: List[Path] = []
    skipped_no_enforcement = 0
    skipped_no_rules = 0
    errors = 0

    for adr_path in adr_files:
        adr_id = adr_id_from_filename(adr_path.name)
        if not adr_id:
            continue

        try:
            content = adr_path.read_text(encoding="utf-8")
        except OSError as e:
            print(f"[adr-generate-scripts] WARN: cannot read {adr_path}: {e}", file=sys.stderr)
            errors += 1
            continue

        try:
            enforcement = extract_enforcement(content)
        except ValueError as e:
            print(f"[adr-generate-scripts] WARN: {adr_path.name}: {e}", file=sys.stderr)
            errors += 1
            continue

        if enforcement is None:
            skipped_no_enforcement += 1
            continue

        written = generate_scripts_for_adr(adr_id, enforcement, output_dir, langs)
        if not written:
            skipped_no_rules += 1
            continue

        total_written.extend(written)
        for p in written:
            print(f"  generated  {p}")

    print(
        f"\n[adr-generate-scripts] done: {len(total_written)} file(s) written, "
        f"{skipped_no_enforcement} ADR(s) without Enforcement skipped, "
        f"{skipped_no_rules} ADR(s) with no forbid rules skipped"
        + (f", {errors} error(s)" if errors else "")
    )
    return 0 if errors == 0 else 2


if __name__ == "__main__":
    sys.exit(main())
