#!/usr/bin/env python3
"""adr-lint: deterministic CLI for the four adr-kit verification gates.

Pairs with the /adr-kit:lint Claude Code skill. Use this CLI in CI / pre-commit
hooks where Claude is not in the loop. Default gates are completeness and
consistency (the deterministic ones). The heuristic gates evidence and clarity
are available behind --gates but are off by default because they need
judgement that a regex cannot reliably provide.

Severity model matches the v0.9.0 skill exactly:
  ignore  >  per-ADR markers  >  config.severity
  always_strict > always_advisory > advisory_before_strict_from

Exit codes:
  0  no FAIL (PASS / ADVISORY / SKIPPED counts may be non-zero)
  1  at least one FAIL
  2  config or input error (malformed JSON, unknown field, bad path)

Usage:
  adr-lint                            # lint docs/adr/, config from docs/adr/.adr-kit.json
  adr-lint docs/decisions/            # lint a different directory
  adr-lint docs/adr/ADR-042-foo.md    # lint a single file
  adr-lint --strict-from ADR-100      # override config strict_from
  adr-lint --gates completeness       # only completeness gate
  adr-lint --format json              # machine-readable output
  adr-lint --config /tmp/policy.json  # custom config path
"""

from __future__ import annotations

import argparse
import json
import os
import re
import sys
from datetime import date
from pathlib import Path
from typing import Dict, List, Optional, Set, Tuple

CANONICAL_REQUIRED_SECTIONS = [
    "## Status",
    "## Context",
    "## Decision",
    "## Alternatives Considered",
    "## Consequences",
    "## Related Decisions",
    "## References",
]

# PERF-MEDIUM: precompile section-heading patterns. gate_completeness used to
# compile these per call per heading per file; for large ADR sets this
# dominated the run.
_SECTION_PATTERNS: Dict[str, "re.Pattern[str]"] = {
    s: re.compile(r"^" + re.escape(s) + r"\b", re.MULTILINE)
    for s in CANONICAL_REQUIRED_SECTIONS
}


def _section_pattern(heading: str) -> "re.Pattern[str]":
    """Return a cached MULTILINE pattern for a `## Heading` line."""
    pat = _SECTION_PATTERNS.get(heading)
    if pat is None:
        pat = re.compile(r"^" + re.escape(heading) + r"\b", re.MULTILINE)
        _SECTION_PATTERNS[heading] = pat
    return pat


# PERF-MEDIUM: cached jsonschema validator for the enforcement block.
_ENFORCEMENT_VALIDATOR = None
_ENFORCEMENT_VALIDATOR_LOADED = False


def _get_enforcement_validator():
    """Return a cached Draft7Validator for the enforcement schema, or None."""
    global _ENFORCEMENT_VALIDATOR, _ENFORCEMENT_VALIDATOR_LOADED
    if _ENFORCEMENT_VALIDATOR_LOADED:
        return _ENFORCEMENT_VALIDATOR
    _ENFORCEMENT_VALIDATOR_LOADED = True
    try:
        import jsonschema  # type: ignore
    except ImportError:
        return None
    schema_path = (
        Path(__file__).resolve().parent.parent
        / "schemas"
        / "adr-enforcement.schema.json"
    )
    if not schema_path.exists():
        return None
    schema = json.loads(schema_path.read_text(encoding="utf-8"))
    _ENFORCEMENT_VALIDATOR = jsonschema.Draft7Validator(schema)
    return _ENFORCEMENT_VALIDATOR

LEGAL_SEVERITIES = {"always_strict", "always_advisory", "advisory_before_strict_from"}
ALL_GATES = ["completeness", "audit", "evidence", "clarity", "consistency", "policy", "quality"]
DEFAULT_GATES = ["completeness", "audit", "consistency"]

ENFORCEMENT_BLOCK_RE = re.compile(
    r"^##\s+Enforcement\s*$\n+(?:.*?\n)*?```json\s*\n(.*?)\n```",
    re.IGNORECASE | re.MULTILINE | re.DOTALL,
)

ENFORCEMENT_KNOWN_KEYS = frozenset({"forbid_pattern", "forbid_import", "require_pattern", "llm_judge"})
ENFORCEMENT_ARRAY_KEYS = frozenset({"forbid_pattern", "forbid_import", "require_pattern"})

MARKER_RE = re.compile(r"<!--\s*adr-kit-lint:\s*([^>]+?)\s*-->", re.IGNORECASE)
ADR_FILENAME_RE = re.compile(r"(?i)^ADR-(\d{1,4})-")
CANONICAL_FILENAME_RE = re.compile(r"^ADR-\d{3}-[a-z0-9-]+\.md$")
HEADING_NUMBER_RE = re.compile(r"^#\s+(?i:ADR)-(\d{1,4})\b")
STATUS_HEADING_RE = re.compile(r"^##\s+Status\s*$\n+([^\n]+)", re.IGNORECASE | re.MULTILINE)
STATUS_LINE_RE = re.compile(r"^Status\s*:?\s*(\w+)", re.IGNORECASE | re.MULTILINE)
STATUS_BOLD_INLINE_RE = re.compile(
    r"^\s*\*\*\s*Status\s*:?\s*\*\*\s*:?\s*([A-Za-z]+)"
    r"|^\s*\*\*\s*Status\s*:?\s*([A-Za-z]+)\s*\*\*",
    re.IGNORECASE | re.MULTILINE,
)
STATUS_HISTORY_START_RE = re.compile(r"^\s*status_history\s*:\s*$", re.IGNORECASE)
STATUS_HISTORY_ITEM_RE = re.compile(r"^\s*-\s*([a-z_]+)\s*:\s*(.*?)\s*$", re.IGNORECASE)
STATUS_HISTORY_FIELD_RE = re.compile(r"^\s+([a-z_]+)\s*:\s*(.*?)\s*$", re.IGNORECASE)
STATUS_HISTORY_REQUIRED_FIELDS = ("date", "status", "changed_by", "reason", "changed_via")


class PolicyError(Exception):
    """Raised when the configuration file is malformed."""


def load_config(path: Optional[Path]) -> Dict:
    """Read .adr-kit.json (if present) and return as a dict.

    Returns an empty dict if path is None or does not exist (default behaviour
    is "no config, everything strict"). Raises PolicyError on malformed JSON or
    unrecognised severity values.
    """
    if path is None or not path.exists():
        return {}
    try:
        cfg = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as e:
        raise PolicyError(f"{path}: invalid JSON ({e.msg} at line {e.lineno})")

    sev = cfg.get("severity")
    if sev is not None:
        if not isinstance(sev, dict):
            raise PolicyError(f"{path}: 'severity' must be an object")
        for gate, value in sev.items():
            if gate not in ALL_GATES:
                raise PolicyError(
                    f"{path}: unknown severity gate {gate!r}; legal: {ALL_GATES}"
                )
            if value not in LEGAL_SEVERITIES:
                raise PolicyError(
                    f"{path}: severity.{gate}={value!r} not legal; "
                    f"must be one of {sorted(LEGAL_SEVERITIES)}"
                )

    sf = cfg.get("strict_from")
    if sf is not None and not re.match(r"^ADR-\d{3}$", sf):
        raise PolicyError(
            f"{path}: strict_from={sf!r} does not match pattern ADR-NNN"
        )

    # Optional jsonschema validation: deeper structural check.
    try:
        import jsonschema
        schema_path = (
            Path(__file__).resolve().parent.parent
            / "schemas"
            / "adr-kit-config.schema.json"
        )
        if schema_path.exists():
            schema = json.loads(schema_path.read_text(encoding="utf-8"))
            jsonschema.validate(cfg, schema)
    except ImportError:
        pass  # jsonschema not installed; basic checks above suffice.
    except Exception as e:
        raise PolicyError(f"{path}: schema validation failed: {e}")

    return cfg


def severity_of(
    gate: str, adr_num: int, cfg: Dict, strict_from_override: Optional[str]
) -> str:
    """Return 'FAIL' or 'ADVISORY' for a gate failure, given the policy."""
    sf_id = strict_from_override or cfg.get("strict_from")
    sf_num = (
        int(re.match(r"ADR-(\d+)", sf_id).group(1)) if sf_id else None
    )
    sev = cfg.get("severity", {})
    default = "advisory_before_strict_from" if sf_id and gate != "consistency" else "always_strict"
    s = sev.get(gate, default)
    if s == "always_strict":
        return "FAIL"
    if s == "always_advisory":
        return "ADVISORY"
    if s == "advisory_before_strict_from":
        return "ADVISORY" if (sf_num is None or adr_num < sf_num) else "FAIL"
    return "FAIL"


def parse_marker(text: str) -> Tuple[bool, bool, Set[str], Optional[str]]:
    """Scan an ADR file body for the first adr-kit-lint marker.

    Returns: (file_skipped, file_advisory, gate_skip_set, raw_directive_or_None).
    """
    for line in text.splitlines():
        m = MARKER_RE.search(line)
        if not m:
            continue
        directive = m.group(1).strip().lower()
        if directive == "skip":
            return True, False, set(), directive
        if directive == "advisory":
            return False, True, set(), directive
        if directive.startswith("skip "):
            gates = {g.strip() for g in directive[5:].split(",")}
            unknown = gates - set(ALL_GATES)
            if unknown:
                # Treat unknown gate names as no-op rather than fail; warn caller.
                gates = gates - unknown
            return False, False, gates, directive
        # Unknown directive: report so the user notices.
        return False, False, set(), f"unknown directive: {directive!r}"
    return False, False, set(), None


def discover_files(target: Path) -> List[Path]:
    """Return ADR files under target. target may be a file or directory."""
    if target.is_file():
        return [target]
    if not target.is_dir():
        return []
    seen = {}
    for p in target.glob("*.md"):
        if ADR_FILENAME_RE.match(p.name):
            seen[p.name.lower()] = p
    return sorted(seen.values(), key=lambda p: p.name.lower())


def gate_completeness(text: str, required: List[str]) -> Optional[List[str]]:
    """Return list of missing required headings, or None if all present."""
    missing = []
    for s in required:
        if not _section_pattern(s).search(text):
            missing.append(s)
    return missing or None


def _yaml_scalar(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] == '"':
        try:
            return str(json.loads(value))
        except json.JSONDecodeError:
            return value[1:-1]
    if len(value) >= 2 and value[0] == value[-1] == "'":
        return value[1:-1].replace("''", "'")
    return value


def _status_history(text: str) -> Tuple[bool, List[Dict[str, str]]]:
    entries: List[Dict[str, str]] = []
    current: Optional[Dict[str, str]] = None
    found = False
    for line in text.splitlines():
        stripped = line.strip()
        if not found:
            if STATUS_HISTORY_START_RE.match(line):
                found = True
            continue
        if stripped.startswith("```") or stripped.startswith("## "):
            break
        if not stripped or stripped.startswith("#"):
            continue
        item = STATUS_HISTORY_ITEM_RE.match(line)
        if item:
            if current is not None:
                entries.append(current)
            current = {item.group(1).lower(): _yaml_scalar(item.group(2))}
            continue
        field = STATUS_HISTORY_FIELD_RE.match(line)
        if field and current is not None:
            current[field.group(1).lower()] = _yaml_scalar(field.group(2))
            continue
        if current is not None:
            break
    if current is not None:
        entries.append(current)
    return found, entries


def _current_status(text: str) -> Optional[str]:
    match = STATUS_HEADING_RE.search(text)
    if match:
        current = re.match(r"\s*([A-Za-z]+)", match.group(1))
        return current.group(1) if current else None
    match = STATUS_BOLD_INLINE_RE.search(text)
    if match:
        return match.group(1) or match.group(2)
    match = STATUS_LINE_RE.search(text)
    return match.group(1) if match else None


def gate_audit(text: str) -> Optional[List[str]]:
    """Validate a present status_history chain; legacy ADRs remain valid."""
    found, entries = _status_history(text)
    if not found:
        return None
    if not entries:
        return ["status_history is present but contains no transition entries"]
    issues: List[str] = []
    previous: Optional[date] = None
    today = date.today()
    for number, entry in enumerate(entries, start=1):
        missing = [key for key in STATUS_HISTORY_REQUIRED_FIELDS if not entry.get(key)]
        if missing:
            issues.append(f"entry {number} missing fields: {', '.join(missing)}")
            continue
        try:
            entry_date = date.fromisoformat(entry["date"])
        except ValueError:
            issues.append(f"entry {number} has invalid date: {entry['date']!r}")
            continue
        if entry_date > today:
            issues.append(f"entry {number} has future date: {entry['date']}")
        if previous is not None and entry_date < previous:
            issues.append(f"entry {number} is earlier than its preceding entry")
        previous = entry_date
    current = _current_status(text)
    if current:
        last = re.match(r"\s*([A-Za-z]+)", entries[-1].get("status", ""))
        if not last or current.lower() != last.group(1).lower():
            issues.append(
                "latest history status does not match the ADR Status section "
                f"({entries[-1].get('status', '')!r} != {current!r})"
            )
    return issues or None


def gate_evidence(text: str) -> Optional[List[Tuple[int, str]]]:
    """Heuristic: bare adjectives without nearby measurement / citation.

    Returns hits (line, text) when 3+ are found. Threshold suppresses noise.
    """
    bare = re.compile(
        r"\b(faster|slower|better|worse|improves|reduces|"
        r"more reliable|more performant|much faster|much slower)\b",
        re.IGNORECASE,
    )
    hits = []
    lines = text.splitlines()
    for i, ln in enumerate(lines):
        if bare.search(ln):
            window = "\n".join(lines[max(0, i - 2):i + 5])
            if not re.search(
                r"\d|http|RFC|spec|datasheet|measured|see\s+\w+:",
                window, re.IGNORECASE,
            ):
                hits.append((i + 1, ln.strip()[:80]))
    return hits if len(hits) >= 3 else None


def gate_clarity(text: str) -> Optional[List[Tuple[int, str]]]:
    """Heuristic: ALL-CAPS acronyms (3 to 5 letters) without inline expansion.

    Conservative: only flag when 3+ distinct acronyms appear without an
    obvious '(<expansion>)' nearby. Off by default; opt in with --gates.
    """
    acro_re = re.compile(r"\b[A-Z]{3,5}\b")
    seen_with_expansion: Set[str] = set()
    flagged: List[Tuple[int, str]] = []
    for i, ln in enumerate(text.splitlines()):
        for m in acro_re.finditer(ln):
            acro = m.group(0)
            # Look for '(...)' immediately after.
            tail = ln[m.end():m.end() + 100]
            if re.match(r"\s*\(", tail):
                seen_with_expansion.add(acro)
                continue
            if acro in seen_with_expansion:
                continue
            flagged.append((i + 1, acro))
    if len({a for _, a in flagged}) >= 3:
        return flagged[:5]
    return None


def gate_consistency(
    fp: Path, adr_num: int, text: str, duplicates: Dict[int, List[str]]
) -> Optional[List[str]]:
    """Filename pattern, heading match, duplicate numbers, etc."""
    issues = []
    first_heading = next(
        (l.strip() for l in text.splitlines() if l.strip().startswith("# ")),
        "",
    )
    m = HEADING_NUMBER_RE.match(first_heading)
    if not m:
        issues.append(f"first heading {first_heading!r} does not match # ADR-NNN")
    elif int(m.group(1)) != adr_num:
        issues.append(
            f"heading number {m.group(1)} != filename {adr_num:03d}"
        )
    if not CANONICAL_FILENAME_RE.match(fp.name):
        issues.append(f"filename {fp.name} does not match ADR-NNN-kebab.md")
    if adr_num in duplicates:
        issues.append(
            f"duplicate ADR-{adr_num:03d}: {duplicates[adr_num]}"
        )
    return issues or None


def _section_text(text: str, heading: str) -> str:
    """Extract text of a markdown section (up to the next ## heading or EOF)."""
    m = re.search(
        rf"^{re.escape(heading)}\s*$\n(.*?)(?=\n##\s+|\Z)",
        text, re.MULTILINE | re.DOTALL,
    )
    return m.group(1) if m else ""


def _extract_enforcement_block(content: str) -> Tuple[Optional[Dict], Optional[str]]:
    """Parse the ## Enforcement JSON block.

    Returns:
      (dict, None)   — parsed successfully
      (None, None)   — section absent (skip silently)
      (None, msg)    — section present but JSON is malformed or invalid
    """
    m = ENFORCEMENT_BLOCK_RE.search(content)
    if not m:
        return None, None
    raw = m.group(1)
    try:
        data = json.loads(raw)
    except json.JSONDecodeError as e:
        return None, f"malformed JSON in ## Enforcement block ({e.msg} at line {e.lineno})"
    if not isinstance(data, dict):
        return None, f"## Enforcement JSON must be an object, got {type(data).__name__}"
    # Manual additionalProperties check (works without jsonschema installed).
    unknown_keys = set(data.keys()) - ENFORCEMENT_KNOWN_KEYS
    if unknown_keys:
        return None, f"## Enforcement block has unknown key(s): {sorted(unknown_keys)}"
    for key in ENFORCEMENT_ARRAY_KEYS:
        if key in data and not isinstance(data[key], list):
            return None, f"Enforcement.{key} must be an array"
    if "llm_judge" in data and not isinstance(data["llm_judge"], bool):
        return None, "Enforcement.llm_judge must be a boolean"
    return data, None


def check_policy_gate(content: str, adr_id: str) -> List[Dict]:
    """Validate the ## Enforcement JSON block in an ADR.

    Returns list of finding dicts:
    {
      "gate": "policy",
      "severity": "FAIL" | "ADVISORY",
      "code": "POLICY_xxx",
      "message": str,
    }
    """
    data, err = _extract_enforcement_block(content)
    if err is not None:
        # Schema / JSON error — FAIL.
        try:
            import jsonschema  # noqa: F401
            code = "POLICY_SCHEMA_INVALID"
        except ImportError:
            code = "POLICY_SCHEMA_INVALID"
        return [{"gate": "policy", "severity": "FAIL", "code": code, "message": err}]
    if data is None:
        # No enforcement block — skip silently.
        return []

    findings: List[Dict] = []

    # Optional: deeper schema validation when jsonschema is available.
    validator = _get_enforcement_validator()
    if validator is not None:
        try:
            validator.validate(data)
        except Exception as ve:
            findings.append({
                "gate": "policy",
                "severity": "FAIL",
                "code": "POLICY_SCHEMA_INVALID",
                "message": f"schema validation failed: {getattr(ve, 'message', str(ve))}",
            })
            return findings

    # Regex compilation checks across all pattern-bearing keys.
    for key in ("forbid_pattern", "forbid_import", "require_pattern"):
        for i, rule in enumerate(data.get(key, [])):
            pat = rule.get("pattern", "")
            try:
                re.compile(pat)
            except re.error as exc:
                findings.append({
                    "gate": "policy",
                    "severity": "FAIL",
                    "code": "POLICY_BAD_REGEX",
                    "message": (
                        f"{key}[{i}].pattern {pat!r} is not a valid regex: {exc}"
                    ),
                })

    # Anti-pattern advisories.
    for key in ("forbid_pattern", "forbid_import", "require_pattern"):
        for i, rule in enumerate(data.get(key, [])):
            pat = rule.get("pattern", "")
            # Excessive wildcard: three or more consecutive .* occurrences.
            if ".*.*.*" in pat:
                findings.append({
                    "gate": "policy",
                    "severity": "ADVISORY",
                    "code": "POLICY_EXCESSIVE_WILDCARD",
                    "message": (
                        f"{key}[{i}].pattern {pat!r} contains excessive wildcards "
                        f"(three or more consecutive .*); this matches almost everything"
                    ),
                })
            # Broad glob: path_glob absent or is pure ** / **/* without further scoping.
            path_glob = rule.get("path_glob", "")
            if not path_glob or path_glob in ("**", "**/*"):
                findings.append({
                    "gate": "policy",
                    "severity": "ADVISORY",
                    "code": "POLICY_BROAD_GLOB",
                    "message": (
                        f"{key}[{i}] has no path_glob or a very broad glob {path_glob!r}; "
                        f"consider scoping to a specific directory or extension"
                    ),
                })

    return findings


def check_quality_gate(content: str, adr_id: str) -> List[Dict]:
    """Advisory quality checks. For comprehensive scoring, use bin/adr-quality (which runs 4 weighted gates with letter grades)."""
    findings: List[Dict] = []

    # Unified vague-words set; identical to bin/adr-quality's VAGUE_WORDS_RE.
    vague_words = re.compile(
        r"\b(appropriate|somehow|maybe|possibly|might|could|"
        r"should\s+consider|might\s+consider)\b",
        re.IGNORECASE,
    )
    decision_text = _section_text(content, "## Decision")
    if vague_words.search(decision_text):
        findings.append({
            "gate": "quality",
            "severity": "ADVISORY",
            "code": "QUALITY_VAGUE_LANGUAGE",
            "message": (
                "## Decision section contains vague language "
                "(appropriate / somehow / maybe / possibly / might / could / "
                "should consider / might consider); "
                "prefer concrete, measurable statements"
            ),
        })

    consequences_text = _section_text(content, "## Consequences")
    if consequences_text and not re.search(r"\d|%", consequences_text):
        findings.append({
            "gate": "quality",
            "severity": "ADVISORY",
            "code": "QUALITY_NO_METRICS",
            "message": (
                "## Consequences section contains no numbers or percentages; "
                "consider quantifying the impact"
            ),
        })

    alternatives_text = _section_text(content, "## Alternatives Considered")
    if alternatives_text:
        # Count list items (- or *) or standalone paragraphs separated by blank lines.
        list_items = re.findall(r"^[-*]\s+\S", alternatives_text, re.MULTILINE)
        heading_items = re.findall(r"^###\s+\S", alternatives_text, re.MULTILINE)
        total_items = len(list_items) + len(heading_items)
        if total_items < 2:
            findings.append({
                "gate": "quality",
                "severity": "ADVISORY",
                "code": "QUALITY_FEW_ALTERNATIVES",
                "message": (
                    f"## Alternatives Considered has {total_items} item(s); "
                    f"consider listing at least 2 alternatives (including 'do nothing')"
                ),
            })

    return findings


def lint_file(
    fp: Path,
    cfg: Dict,
    strict_from_override: Optional[str],
    enabled_gates: Set[str],
    duplicates: Dict[int, List[str]],
    required_sections: List[str],
    ignore: Set[str],
) -> Dict:
    """Lint one file. Returns a dict ready for JSON serialisation."""
    m = ADR_FILENAME_RE.match(fp.name)
    adr_num = int(m.group(1)) if m else -1
    adr_id = f"ADR-{adr_num:03d}"

    if adr_id in ignore or fp.name in ignore:
        return {"file": fp.name, "adr_num": adr_num, "bucket": "SKIPPED",
                "skip_reason": "config.ignore", "findings": []}

    text = fp.read_text(encoding="utf-8", errors="replace")
    file_skipped, file_advisory, skip_gates, _ = parse_marker(text)
    if file_skipped:
        return {"file": fp.name, "adr_num": adr_num, "bucket": "SKIPPED",
                "skip_reason": "marker", "findings": []}

    findings = []

    if "completeness" in enabled_gates and "completeness" not in skip_gates:
        miss = gate_completeness(text, required_sections)
        if miss:
            level = "ADVISORY" if file_advisory else severity_of(
                "completeness", adr_num, cfg, strict_from_override
            )
            findings.append({
                "gate": "completeness", "level": level,
                "details": [s.replace("## ", "") for s in miss],
                "summary": f"missing sections: {[s.replace('## ', '') for s in miss]}",
            })

    if "audit" in enabled_gates and "audit" not in skip_gates:
        issues = gate_audit(text)
        if issues:
            level = "ADVISORY" if file_advisory else severity_of(
                "audit", adr_num, cfg, strict_from_override
            )
            findings.append({
                "gate": "audit", "level": level,
                "details": issues, "summary": "; ".join(issues),
            })

    if "evidence" in enabled_gates and "evidence" not in skip_gates:
        hits = gate_evidence(text)
        if hits:
            level = "ADVISORY" if file_advisory else severity_of(
                "evidence", adr_num, cfg, strict_from_override
            )
            findings.append({
                "gate": "evidence", "level": level,
                "details": [{"line": l, "text": t} for l, t in hits],
                "summary": f"{len(hits)} bare-adjective hit(s) without nearby measurement",
            })

    if "clarity" in enabled_gates and "clarity" not in skip_gates:
        hits = gate_clarity(text)
        if hits:
            level = "ADVISORY" if file_advisory else severity_of(
                "clarity", adr_num, cfg, strict_from_override
            )
            findings.append({
                "gate": "clarity", "level": level,
                "details": [{"line": l, "acronym": a} for l, a in hits],
                "summary": f"{len({a for _, a in hits})} acronym(s) without inline expansion",
            })

    if "consistency" in enabled_gates and "consistency" not in skip_gates:
        issues = gate_consistency(fp, adr_num, text, duplicates)
        if issues:
            level = "ADVISORY" if file_advisory else severity_of(
                "consistency", adr_num, cfg, strict_from_override
            )
            findings.append({
                "gate": "consistency", "level": level,
                "details": issues, "summary": "; ".join(issues),
            })

    if "policy" in enabled_gates and "policy" not in skip_gates:
        policy_findings = check_policy_gate(text, adr_id)
        for pf in policy_findings:
            # Intrinsic severity: FAIL for schema/regex errors, ADVISORY for anti-patterns.
            # Demote to ADVISORY if the whole file is marked advisory.
            level = "ADVISORY" if file_advisory else pf["severity"]
            findings.append({
                "gate": "policy",
                "level": level,
                "code": pf["code"],
                "details": [pf["message"]],
                "summary": pf["message"],
            })

    if "quality" in enabled_gates and "quality" not in skip_gates:
        quality_findings = check_quality_gate(text, adr_id)
        for qf in quality_findings:
            # Quality is always ADVISORY — demoting doesn't change anything, but
            # honour file_advisory marker for uniformity.
            findings.append({
                "gate": "quality",
                "level": "ADVISORY",
                "code": qf["code"],
                "details": [qf["message"]],
                "summary": qf["message"],
            })

    levels = {f["level"] for f in findings}
    bucket = "PASS" if not findings else ("FAIL" if "FAIL" in levels else "ADVISORY")

    return {"file": fp.name, "adr_num": adr_num, "bucket": bucket, "findings": findings}


def detect_duplicates(files: List[Path]) -> Dict[int, List[str]]:
    grouped: Dict[int, List[str]] = {}
    for fp in files:
        m = ADR_FILENAME_RE.match(fp.name)
        if m:
            grouped.setdefault(int(m.group(1)), []).append(fp.name)
    return {n: lst for n, lst in grouped.items() if len(lst) > 1}


def render_human(result: Dict, verbose: bool) -> str:
    out = []
    s = result["summary"]
    out.append(f"Linting {result['target']} ({s['total']} ADRs)")
    if result["config_path"]:
        cfg_str = "; ".join(
            f"{k}={v}" for k, v in result["config_summary"].items()
        )
        out.append(f"Config: {result['config_path']} ({cfg_str})")
    elif result["strict_from_override"]:
        out.append(f"Config: command-line --strict-from {result['strict_from_override']}")
    out.append("")
    out.append(f"PASS strictly ({s['pass']}):")
    for f in result["files"]:
        if f["bucket"] == "PASS":
            out.append(f"  {f['file']}")
    out.append("")
    out.append(f"ADVISORY only ({s['advisory']}):")
    if verbose:
        for f in result["files"]:
            if f["bucket"] == "ADVISORY":
                out.append(f"  {f['file']}")
                for fnd in f["findings"]:
                    out.append(f"    {fnd['gate']} ADVISORY: {fnd['summary']}")
    else:
        out.append(f"  ({s['advisory']} files; pass --verbose for detail)")
    out.append("")
    out.append(f"FAIL ({s['fail']}):")
    for f in result["files"]:
        if f["bucket"] == "FAIL":
            out.append(f"  {f['file']}")
            for fnd in f["findings"]:
                if fnd["level"] == "FAIL":
                    out.append(f"    {fnd['gate']} FAIL: {fnd['summary']}")
    out.append("")
    out.append(f"SKIPPED ({s['skipped']})")
    if verbose and s["skipped"]:
        for f in result["files"]:
            if f["bucket"] == "SKIPPED":
                out.append(f"  {f['file']} (reason: {f.get('skip_reason', '?')})")
    out.append("")
    out.append("Aggregate:")
    if s["fail"] > 0:
        # Find ADR with most FAIL gates.
        worst = max(
            (f for f in result["files"] if f["bucket"] == "FAIL"),
            key=lambda f: sum(1 for fnd in f["findings"] if fnd["level"] == "FAIL"),
        )
        n_fail_gates = sum(
            1 for fnd in worst["findings"] if fnd["level"] == "FAIL"
        )
        out.append(
            f"  Next steps: focus on {worst['file']}, "
            f"which fails {n_fail_gates} of 4 gates."
        )
    else:
        out.append(
            f"  All linted ADRs pass at the configured severity. "
            f"{s['advisory']} ADVISORY findings remain, treated as informational."
        )
    return "\n".join(out)


def render_json(result: Dict) -> str:
    return json.dumps(result, indent=2, ensure_ascii=False)


def parse_gates(arg: Optional[str]) -> Set[str]:
    if not arg:
        return set(DEFAULT_GATES)
    if arg.strip().lower() == "all":
        return set(ALL_GATES)
    parts = {p.strip() for p in arg.split(",") if p.strip()}
    unknown = parts - set(ALL_GATES)
    if unknown:
        raise ValueError(
            f"unknown gate(s) {sorted(unknown)}; legal: {ALL_GATES}"
        )
    return parts


def main(argv: Optional[List[str]] = None) -> int:
    parser = argparse.ArgumentParser(
        prog="adr-lint",
        description="Deterministic CLI for the four adr-kit verification gates.",
    )
    parser.add_argument(
        "path", nargs="?", default="docs/adr/",
        help="File or directory to lint (default: docs/adr/)",
    )
    parser.add_argument(
        "--strict-from", metavar="ADR-NNN", default=None,
        help="First ADR id (inclusive) on which gates are strict; overrides config.",
    )
    parser.add_argument(
        "--gates", default=None,
        help=f"Comma-separated gates to run. Default: {','.join(DEFAULT_GATES)}. "
             f"All: {','.join(ALL_GATES)}",
    )
    parser.add_argument(
        "--format", choices=["human", "text", "json"], default="human",
        help="Output format (default: human). 'text' is an alias for 'human'.",
    )
    parser.add_argument(
        "--config", metavar="PATH", default=None,
        help="Override .adr-kit.json location (default: <path>/.adr-kit.json)",
    )
    parser.add_argument(
        "-v", "--verbose", action="store_true",
        help="Show ADVISORY and SKIPPED details too",
    )
    parser.add_argument(
        "--version", action="version", version="adr-lint 0.15.0",
    )
    args = parser.parse_args(argv)

    target = Path(args.path)
    if not target.exists():
        print(f"adr-lint: path not found: {target}", file=sys.stderr)
        return 2

    try:
        gates = parse_gates(args.gates)
    except ValueError as e:
        print(f"adr-lint: {e}", file=sys.stderr)
        return 2

    config_path = (
        Path(args.config) if args.config
        else (target / ".adr-kit.json" if target.is_dir()
              else target.parent / ".adr-kit.json")
    )
    try:
        cfg = load_config(config_path if config_path.exists() else None)
    except PolicyError as e:
        print(f"adr-lint: {e}", file=sys.stderr)
        return 2

    ignore = set(cfg.get("ignore", []))
    required_sections = cfg.get("template", {}).get(
        "required_sections", CANONICAL_REQUIRED_SECTIONS
    )

    files = discover_files(target)
    if not files:
        if args.format == "json":
            print(json.dumps({
                "summary": {"total": 0, "pass": 0, "advisory": 0, "fail": 0, "skipped": 0},
                "config_path": str(config_path) if config_path.exists() else None,
                "files": [], "exit_code": 0,
            }))
        else:
            print(f"No ADRs found at {target}.")
        return 0

    duplicates = detect_duplicates(files)

    file_results = [
        lint_file(
            fp, cfg, args.strict_from, gates, duplicates,
            required_sections, ignore,
        ) for fp in files
    ]

    counts = {"pass": 0, "advisory": 0, "fail": 0, "skipped": 0, "total": len(file_results)}
    for r in file_results:
        b = r["bucket"]
        counts[b.lower()] += 1

    config_summary = {}
    if cfg.get("strict_from") or args.strict_from:
        config_summary["strict_from"] = args.strict_from or cfg["strict_from"]
    if cfg.get("severity"):
        for g, v in cfg["severity"].items():
            config_summary[f"severity.{g}"] = v
    if cfg.get("template", {}).get("required_sections"):
        config_summary["template_override"] = "yes"

    result = {
        "target": str(target),
        "config_path": str(config_path) if config_path.exists() else None,
        "config_summary": config_summary,
        "strict_from_override": args.strict_from,
        "gates_enabled": sorted(gates),
        "summary": counts,
        "files": file_results,
        "exit_code": 1 if counts["fail"] > 0 else 0,
    }

    if args.format == "json":
        print(render_json(result))
    else:
        print(render_human(result, args.verbose))

    return result["exit_code"]


if __name__ == "__main__":
    sys.exit(main())
