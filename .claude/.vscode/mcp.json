{
  "inputs": [
    {
      "type": "promptString",
      "id": "discord-token",
      "description": "Discord Bot Token",
      "password": true
    }
  ],
  "servers": {
    "backlog": {
      "type": "stdio",
      "command": "backlog",
      "args": ["mcp", "start"],
      "env": {
        "BACKLOG_CWD": "${workspaceFolder}"
      }
    },
    "discord": {
      "type": "stdio",
      "command": "npx",
      "args": ["mcp-discord"],
      "env": {
        "DISCORD_TOKEN": "${input:discord-token}"
      }
    }
  }
}
